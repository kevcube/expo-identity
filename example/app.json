{
  "expo": {
    "name": "expo-identity-example",
    "slug": "expo-identity-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "expo-identity",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "expo.modules.identity.example"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "expo.modules.identity.example"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "output": "server"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ],
      [
        "expo-identity",
        {
          "ios": {
            "usageDescription": "This app uses identity verification to demonstrate secure age verification with an identity document in Apple Wallet.",
            "merchantIdentifiers": [
              "PassKit_Identity_Test_Merchant_ID",
              "merchant.dog.icecube.identitytest"
            ],
            "documentTypes": [
              "us-drivers-license"
            ],
            "elements": [
              "age"
            ]
          }
        }
      ],
      "./plugins/withIosSceneLifecycle",
      "expo-dev-menu",
      "expo-router"
    ]
  }
}
